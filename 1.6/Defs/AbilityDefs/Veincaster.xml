<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
	<defName>VPE_BloodLink_STNL</defName>
	<label>Blood-Link</label>
	<description>Links the caster to another creature capable of bleeding. Upon blood loss, the user will draw blood from the connected creature to keep themselves alive.\n\nThis ability will not draw blood from the connected creature if the severity of its blood loss exceeds the safety threshold.\n\nOnly one creature may be linked to at all times.\n\nLinking to another creature will sever the previous link.</description>
	<iconPath>UI_Veincaster_STNL/Abilities/Bloodlink</iconPath>
	<abilityClass>VPE_Veincaster.Ability_BloodLink</abilityClass>
	<castSound>PsycastPsychicPulse</castSound>
	<castTime>30</castTime>
	<!-- <durationTime>2500</durationTime> -->
	<!-- <durationTimeStatFactors> -->
		<!-- <PsychicSensitivity>1</PsychicSensitivity> -->
	<!-- </durationTimeStatFactors> -->
	<chance>0</chance>
	<range>14.9</range>
	<targetMode>Pawn</targetMode>
	<targetingParameters>
		<canTargetLocations>false</canTargetLocations>
		<canTargetSelf>true</canTargetSelf>
		<canTargetAnimals>true</canTargetAnimals>
		<canTargetPawns>true</canTargetPawns>
		<canTargetHumans>true</canTargetHumans>
		<canTargetMechs>false</canTargetMechs>
		<canTargetItems>true</canTargetItems>
		<mapObjectTargetsMustBeAutoAttackable>false</mapObjectTargetsMustBeAutoAttackable>
	</targetingParameters>
	<radius>0</radius>
	<needsTicking>true</needsTicking>
	<showUndrafted>True</showUndrafted>
	<goodwillImpact>0</goodwillImpact>
	<modExtensions>
		<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
			<path>VPE_Veincaster_STNL</path>
			<level>1</level>
			<order>2</order>
			<psyfocusCost>0.15</psyfocusCost>
			<entropyGain>0</entropyGain>
			<!-- <prerequisites> -->
			<!-- <li>VPE_ScarletPurgeSTNL</li> -->
			<!-- </prerequisites> -->
		</li>
	</modExtensions>
</VEF.Abilities.AbilityDef>

