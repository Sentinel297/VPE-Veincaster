<HediffDef>
	<defName>VPE_BloodConvergence_Passive_STNL</defName>
	<label>Blood Convergence</label>
	<description>This Veincaster possesses the ability to absorb nearby blood. Doing so will restore their own blood supplies or refill the linked pawn's blood if the former isn't bleeding.</description>
	<hediffClass>VPE_Veincaster.Hediff_BloodConvergence</hediffClass>
	<initialSeverity>1</initialSeverity>
	<minSeverity>0</minSeverity>
	<maxSeverity>1</maxSeverity>
	<!-- <lethalSeverity>1</lethalSeverity> -->
	<defaultLabelColor>(0.6, 0, 0)</defaultLabelColor>
	<makesSickThought>false</makesSickThought>
	<scenarioCanAdd>false</scenarioCanAdd>
	<isBad>false</isBad>
	<everCurableByItem>false</everCurableByItem>
	<keepOnBodyPartRestoration>True</keepOnBodyPartRestoration>
	<stages>
		<li>
		</li>
	</stages>
	<modExtensions>
		<li Class="VPE_Veincaster.ConvergenceModExt">
			<!-- Moved to ingame settings -->
			<!-- <bloodRestoredBySingleFilth>0.02</bloodRestoredBySingleFilth> -->
			<bloodAbsorptionRadius>2.9</bloodAbsorptionRadius>
			<filthDefs>
				<li>Filth_Blood</li>
				<li>Filth_BloodSmear</li>
				<li>Filth_BloodInsect</li>
			</filthDefs>
		</li>
	</modExtensions>
	<comps>
		<!-- <li Class="HediffCompProperties_Disappears"> -->
		<!-- <disappearsAfterTicks>601</disappearsAfterTicks> -->
		<!-- <showRemainingTime>false</showRemainingTime> -->
