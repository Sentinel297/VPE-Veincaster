<Defs>



<HediffDef>
	<defName>VPE_BloodStabilize_STNL</defName>
	<label>Stabilized</label>
	<description>This creature's blood cannot leave its body as an after-effect of being stabilized.</description>
	<hediffClass>HediffWithComps</hediffClass>
	<initialSeverity>1</initialSeverity>
	<minSeverity>0</minSeverity>
	<maxSeverity>1</maxSeverity>
	<!-- <lethalSeverity>1</lethalSeverity> -->
	<defaultLabelColor>(0.75, 0, 0)</defaultLabelColor>
	<makesSickThought>false</makesSickThought>
	<scenarioCanAdd>false</scenarioCanAdd>
	<isBad>false</isBad>
	<everCurableByItem>false</everCurableByItem>
	<keepOnBodyPartRestoration>True</keepOnBodyPartRestoration>
	<stages>
		<li>
			<totalBleedFactor>0</totalBleedFactor>
		</li>
	</stages>
	<comps>
		<li Class="HediffCompProperties_Disappears">
			<disappearsAfterTicks>12500</disappearsAfterTicks>
			<showRemainingTime>true</showRemainingTime>
		</li>
		<!-- <li Class="HediffCompProperties_Effecter"> -->
		<!-- <stateEffecter>VPE_CarmineAspectSTNL</stateEffecter> -->
		<!-- </li> -->
	</comps>
</HediffDef>

